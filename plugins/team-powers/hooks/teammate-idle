#!/usr/bin/env bash
# TeammateIdle hook: remind idle teammates to check for unclaimed tasks
# Exit code 2 = send feedback and keep teammate working
# Exit code 0 = allow teammate to go idle

set -euo pipefail

# Read hook input from stdin
INPUT=$(cat)

# Extract team name from the hook input
TEAM_NAME=$(echo "$INPUT" | grep -o '"team_name" *: *"[^"]*"' | head -1 | sed 's/.*: *"//;s/"//' 2>/dev/null || true)

# Check if there are pending unassigned tasks in the task directory
HAS_PENDING=false
if [[ -n "$TEAM_NAME" ]]; then
    TASK_DIR="$HOME/.claude/tasks/$TEAM_NAME"
    if [[ -d "$TASK_DIR" ]]; then
        # Look for tasks with status "pending" and no owner
        shopt -s nullglob
        for f in "$TASK_DIR"/*.json; do
            status=$(grep -o '"status" *: *"[^"]*"' "$f" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//' || true)
            owner=$(grep -o '"owner" *: *"[^"]*"' "$f" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//' || true)
            if [[ "$status" == "pending" && -z "$owner" ]]; then
                HAS_PENDING=true
                break
            fi
        done
    fi
fi

if [[ "$HAS_PENDING" == true ]]; then
    cat <<'EOF'
{
  "hookSpecificOutput": {
    "hookEventName": "TeammateIdle",
    "feedback": "There are unclaimed pending tasks. Check TaskList and claim one before going idle."
  }
}
EOF
    exit 2
fi

# No pending tasks — allow idle
exit 0
