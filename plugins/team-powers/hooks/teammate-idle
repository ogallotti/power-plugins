#!/usr/bin/env bash
# TeammateIdle hook
# Exit 2 = send feedback, keep teammate working
# Exit 0 = allow idle

set -euo pipefail

INPUT=$(cat)

# Extract a JSON string field from stdin/file
json_val() { grep -o "\"$1\" *: *\"[^\"]*\"" "$2" 2>/dev/null | head -1 | sed 's/.*: *"//;s/"//'; }

# Get team name via bash regex (no subprocess)
TEAM_NAME=""
if [[ "$INPUT" =~ \"team_name\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
    TEAM_NAME="${BASH_REMATCH[1]}"
fi

if [[ -n "$TEAM_NAME" ]]; then
    TASK_DIR="$HOME/.claude/tasks/$TEAM_NAME"
    if [[ -d "$TASK_DIR" ]]; then
        shopt -s nullglob
        for f in "$TASK_DIR"/*.json; do
            [[ "$(json_val status "$f")" == "pending" ]] || continue
            if [[ -z "$(json_val owner "$f" || true)" ]]; then
                cat <<'EOF'
{
  "hookSpecificOutput": {
    "hookEventName": "TeammateIdle",
    "feedback": "There are unclaimed pending tasks. Check TaskList and claim one before going idle."
  }
}
EOF
                exit 2
            fi
        done
    fi
fi

exit 0
