#!/usr/bin/env bash
# SessionStart hook for team-powers plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_tp_content=$(cat "${PLUGIN_ROOT}/skills/using-team-powers/SKILL.md" 2>&1 || echo "Error reading using-team-powers skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_tp_escaped=$(escape_for_json "$using_tp_content")
session_context="<EXTREMELY_IMPORTANT>\nYou have team-powers.\n\n**Below is the full content of your 'team-powers:using-team-powers' skill - your introduction to using skills. For all other skills, use the 'Skill' tool:**\n\n${using_tp_escaped}\n\n</EXTREMELY_IMPORTANT>"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF
else
  cat <<EOF
{
  "additional_context": "${session_context}"
}
EOF
fi

exit 0
